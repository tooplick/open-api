# 复制为 .env 后按需修改。docker compose 会自动读取本目录下的 .env。
# 注意:这些变量仅对 `docker compose` 生效,不影响本地 `mvn spring-boot:run`。
# 真实的 .env 已被 .gitignore 忽略,请勿提交含密钥的 .env。

# JWT 签名密钥 —— 生产环境必须改成足够长(>=32 字节)的随机字符串
AIOPEN_JWT_SECRET=change-me-please-use-a-long-random-secret-key-2026

# MySQL root 密码(mysql 容器与后端数据源共用此值)
MYSQL_PASSWORD=root

# 对外暴露的端口(容器内固定监听 8321)
APP_PORT=8321
